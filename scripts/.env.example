# Copy this file to scripts/.env (gitignored) and fill in real values.
# Used by Python scripts via _sb_config.py.

# REQUIRED post-RLS-migration: service-role key (bypasses RLS).
# Get from Supabase dashboard → Project Settings → API → service_role (secret).
# Treat like a password — never commit, never paste into chat or screenshots.
SUPABASE_SERVICE_KEY=

# Optional override (defaults to carfactory's project URL):
# SUPABASE_URL=https://hphlouzqlimainczuqyc.supabase.co

# Legacy: anon key. Only useful before Phase 4 RLS rollout. Will not work
# against locked-down tables once RLS is on.
# SUPABASE_ANON_KEY=
